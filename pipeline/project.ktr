  <step>
    <name>Modified JavaScript value</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// Initialize the output variables
var tokens_a = 0;
var tokens_b = 0;

// Helper function to safely parse the array, find the assistant, and count tokens
function getAssistantTokens(conversation_string) {
    // Check for null or empty data
    if (conversation_string == null || conversation_string == "") {
        return 0;
    }

    try {
        // Pentaho passes complex Parquet structs as JSON strings, so we parse it into a JS array
        var conv_array = JSON.parse(conversation_string);
        var total_tokens = 0;

        // Use a standard for-loop (Safest method for Pentaho's Rhino engine)
        for (var i = 0; i &lt; conv_array.length; i++) {
            if (conv_array[i].role == "assistant" &amp;&amp; conv_array[i].content != null) {
                // Split the content by spaces to get the word count
                var word_count = conv_array[i].content.split(/\s+/).length;
                
                // Multiply by 1.3 to estimate tokens and add to the running total
                total_tokens = total_tokens + Math.round(word_count * 1.3);
            }
        }
        return total_tokens;
    } catch (e) {
        // If parsing fails, return 0 instead of crashing the pipeline
        return 0;
    }
}

// Execute the function for both columns
tokens_a = getAssistantTokens(conversation_a);
tokens_b = getAssistantTokens(conversation_b);


// Convert Unix Timestamp (tstamp) to Date_ID (YYYYMMDD)
var date_id = null;

if (tstamp != null) {
    // tstamp is in seconds, JavaScript Date requires milliseconds
    var date_obj = new Date(tstamp * 1000);
    var year = date_obj.getFullYear();
    var month = ("0" + (date_obj.getMonth() + 1)).slice(-2); // Adds leading zero if needed
    var day = ("0" + date_obj.getDate()).slice(-2);

    // Parse it back into an integer: e.g., 20230424
    date_id = parseInt(year + month + day, 10);
}</jsScript_script>
      </jsScript>
    </jsScripts>
